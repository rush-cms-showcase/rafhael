---
import BlogPostPage from '@/components/pages/blog-post-page.astro'
import { rush, type BlogPost } from '@/lib/rush'

export async function getStaticPaths() {
    try {
        const response = await rush.getEntries('blog', {
            per_page: 100,
            locale: 'en'
        })
        const listPosts = (response as any).data as BlogPost[]

        // Workaround: Fetch full details for each post to ensure correct locale content
        // The List API endpoint currently returns default locale for content body
        const posts = await Promise.all(listPosts.map(async (p) => {
            try {
                // Ensure we call specific entry endpoint
                const fullPost = await rush.entries.getBySlug('blog', p.slug, { locale: 'en' })
                return fullPost as BlogPost
            } catch (err) {
                console.error(`Error fetching detail for ${p.slug}, using list data:`, err)
                return p
            }
        }))

        return posts.map((post) => ({
            params: { slug: post.slug },
            props: { post },
        }))
    } catch (error) {
        console.error('Error fetching paths for blog:', error)
        return []
    }
}

const { post } = Astro.props as { post: BlogPost }
---

<BlogPostPage post={post} locale="en" />
