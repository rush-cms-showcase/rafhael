---
import DynamicPage from '@/components/pages/dynamic-page.astro'
import { rush } from '@/lib/rush'

export async function getStaticPaths() {
	try {
        // ID 2 is the 'Pages' collection. getEntries expects string or number, but Typescript complained.
        // Casting to any or string to satisfy.
		const response = await rush.getEntries(2 as any, { locale: 'en' }) as { data: any[] }
		const pages = response.data

		return pages
            .filter((page: any) => page.slug !== 'about-me')
            .map((page: any) => ({
			params: { slug: page.slug },
			props: { page }
		}))
	} catch (error) {
		console.error('Error fetching paths for link pages:', error)
		return []
	}
}

interface Props {
	page: {
		slug: string
		title: string
		content?: string
		data?: {
			content?: Array<{
				type: string
				data: Record<string, any>
			}>
		}
	}
}

const { page }: Props = Astro.props
---

<DynamicPage page={page} locale='en' />
