---
import Container from '@/components/ui/container.astro'
import Section from '@/components/ui/section.astro'
import { Icons } from '@/lib/icons'
import type { HomeContent } from '@/content/home'

const MapPinIcon = Icons.map_pin
const GlobeIcon = Icons.globe
const MonitorIcon = Icons.monitor

interface Props {
    content: HomeContent['beyond']
}

const { content } = Astro.props
---

<Section>
    <Container>
        <div class='max-w-3xl mx-auto'>
            <div class='text-center mb-12'>
                <h2 class='font-serif text-4xl md:text-5xl font-bold'>
                    {content.title}
                </h2>
            </div>

            <div class='space-y-6'>
                {content.paragraphs.map((paragraph, i) => (
                    <div class='flex gap-6 items-start group'>
                        <div class='shrink-0 w-8 h-8 rounded-full bg-primary/10 border border-primary/20 flex items-center justify-center text-primary text-sm font-bold mt-0.5 group-hover:bg-primary/20 transition-colors duration-300'>
                            {i + 1}
                        </div>
                        <p class='text-text-muted text-lg leading-relaxed pt-0.5'>
                            {paragraph}
                        </p>
                    </div>
                ))}
            </div>

            <div class='mt-12 pt-8 border-t border-border flex flex-wrap gap-6 items-center'>
                <div class='flex items-center gap-2 text-text-muted text-sm'>
                    <MapPinIcon class='w-4 h-4' />
                    {content.location}
                </div>
                <div class='flex items-center gap-2 text-text-muted text-sm'>
                    <GlobeIcon class='w-4 h-4' />
                    {content.language}
                </div>
                <div class='flex items-center gap-2 text-text-muted text-sm'>
                    <MonitorIcon class='w-4 h-4' />
                    {content.workStyle}
                </div>
            </div>
        </div>
    </Container>
</Section>
