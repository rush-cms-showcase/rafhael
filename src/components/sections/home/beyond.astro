---
import Container from '@/components/ui/container.astro'
import Section from '@/components/ui/section.astro'
import { Icons } from '@/lib/icons'
import type { HomeContent } from '@/content/home'

const IconSquareCheck = Icons.square_check

interface Props {
    content: HomeContent['beyond']
}

const { content } = Astro.props
---

<div class="flex flex-col items-start justify-center gap-4 lg:gap-6">
    <h2 class="font-serif text-primary text-4xl md:text-5xl font-bold">
        {content.title}
    </h2>

    <div class="space-y-6">
        {
            content.paragraphs.map((paragraph, i) => (
                <p class="text-text-muted text-lg leading-relaxed pt-0.5">{paragraph}</p>
            ))
        }
    </div>

    <div class="flex flex-col gap-2 lg:gap-4 items-start gap-2 lg:gap-4">
        {
            ([content.location, content.language, content.workStyle] as const).map((item) => (
                <div class="flex items-center gap-2 text-text-muted">
                    <IconSquareCheck class="w-6 h-6 text-primary" />
                    {item}
                </div>
            ))
        }
    </div>
</div>
