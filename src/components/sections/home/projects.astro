---
import Container from '@/components/ui/container.astro'
import Section from '@/components/ui/section.astro'
import { Icons } from '@/lib/icons'
import type { HomeContent } from '@/content/home'

const ExternalLinkIcon = Icons['external-link']

interface Props {
    content: HomeContent['projects']
}

const { content } = Astro.props

const typeBadge: Record<string, { label: string; class: string }> = {
    client: { label: 'Client', class: 'bg-blue-500/10 text-blue-400 border-blue-500/20' },
    product: { label: 'Own Product', class: 'bg-primary/10 text-primary border-primary/20' },
    opensource: { label: 'Open Source', class: 'bg-green-500/10 text-green-400 border-green-500/20' },
}
---

<Section>
    <Container>
        <div class='text-center mb-14'>
            <h2 class='font-serif text-4xl md:text-5xl font-bold'>
                {content.title}
            </h2>
        </div>

        <div class='grid md:grid-cols-3 gap-6'>
            {content.items.map((project) => {
                const badge = typeBadge[project.type] ?? typeBadge.client;
                return (
                    <div class='group flex flex-col bg-bg-card border border-border rounded-2xl p-7 hover:border-primary/40 transition-all duration-300 hover:-translate-y-1'>
                        <div class='flex items-start justify-between gap-3 mb-5'>
                            <div>
                                <h3 class='font-serif text-xl font-bold mb-1'>{project.name}</h3>
                                <span class='text-text-muted text-xs'>{project.period}</span>
                            </div>
                            <span class={`shrink-0 text-xs font-semibold px-2.5 py-1 rounded-full border ${badge.class}`}>
                                {badge.label}
                            </span>
                        </div>

                        <p class='text-primary/80 text-sm font-medium mb-3'>
                            {project.role}
                        </p>

                        <p class='text-text-muted text-sm leading-relaxed mb-5 flex-1'>
                            {project.description}
                        </p>

                        <div class='flex flex-wrap gap-2 mb-5'>
                            {project.tags.map((tag) => (
                                <span class='text-xs px-2.5 py-1 rounded-lg bg-bg-elevated border border-border text-text-muted'>
                                    {tag}
                                </span>
                            ))}
                        </div>

                        {project.link && (
                            <a
                                href={project.link}
                                target='_blank'
                                rel='noopener noreferrer'
                                class='inline-flex items-center gap-1.5 text-sm text-primary font-medium hover:gap-2.5 transition-all duration-200'
                            >
                                Visit project
                                <ExternalLinkIcon class='w-3.5 h-3.5' />
                            </a>
                        )}
                    </div>
                );
            })}
        </div>
    </Container>
</Section>
