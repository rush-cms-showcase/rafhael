---
import Particles from "../../ui/particles.astro";
import Container from "../../ui/container.astro";
import Button from "../../ui/button.astro";
import type { HomeContent } from "../../../content/home";

interface Props {
    content: HomeContent["hero"];
}

const { content } = Astro.props;
const scheduleUrl = import.meta.env.PUBLIC_SCHEDULE_URL ?? "https://cal.com/rafhael";
const hasArrayStats = Array.isArray(content.stats);
const statsArray = hasArrayStats ? (content.stats as Array<{ value: string; label: string }>) : [];
---

<section
    class="relative min-h-[90vh] flex items-center pt-32 pb-20 overflow-hidden"
>
    <Particles />

    <div class="absolute inset-0 pointer-events-none">
        <div
            class="absolute top-0 right-0 w-[60%] h-full bg-[radial-gradient(ellipse_at_70%_30%,var(--color-primary)_0%,transparent_60%)] opacity-10"
        >
        </div>
    </div>

    <Container>
        <div class="grid lg:grid-cols-2 gap-16 items-center">
            <div class="relative z-10 max-lg:text-center">
                <h1
                    class="font-serif text-5xl md:text-6xl font-bold leading-tight mb-6 animate-fade-in delay-100"
                    set:html={content.title}
                />

                <p
                    class="text-text-muted text-lg md:text-xl mb-10 max-w-lg leading-relaxed animate-fade-in delay-200"
                    set:html={content.subtitle}
                />

                <div
                    class="flex max-lg:justify-center flex-wrap gap-4 animate-fade-in-up delay-300"
                >
                    <Button
                        href={scheduleUrl}
                        variant="primary"
                        size="lg"
                        className="shadow-[0_10px_40px_rgba(63,145,240,0.3)]"
                    >
                        {content.ctaPrimary}
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        ><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                    </Button>
                    <Button
                        href="https://github.com/rmarsigli"
                        variant="outline"
                        size="lg"
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                        ><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"></path></svg>
                        {content.ctaSecondary}
                    </Button>
                </div>
            </div>

            {hasArrayStats && (
                <div class="relative z-10 animate-fade-in delay-500 hidden lg:flex flex-col gap-4">
                    <div class="grid grid-cols-3 gap-4">
                        {statsArray.map((stat) => (
                            <div class="bg-bg-card border border-border rounded-xl p-6 flex flex-col gap-1 hover:border-primary/40 transition-colors duration-300">
                                <span class="text-3xl font-bold text-primary font-mono">{stat.value}</span>
                                <span class="text-text-muted text-sm leading-snug">{stat.label}</span>
                            </div>
                        ))}
                    </div>
                    <div class="bg-bg-card border border-border rounded-xl p-5 font-mono text-sm leading-relaxed text-text-muted">
                        <span class="text-primary">class</span> <span class="text-green-400">RafhaelMarsigli</span> <span class="text-text-muted">{`{`}</span><br/>
                        &nbsp;&nbsp;<span class="text-blue-400">role</span> = <span class="text-amber-300">'Senior Full-Stack Engineer' <span class="text-text-muted/40">// with hands-on infrastructure & architecture ownership</span></span><br/>
                        &nbsp;&nbsp;<span class="text-blue-400">stack</span> = [<span class="text-amber-300">'PHP'</span>, <span class="text-amber-300">'Laravel'</span>, <span class="text-amber-300">'React'</span>, <span class="text-amber-300">'Typescript'</span>]<br/>
                        &nbsp;&nbsp;<span class="text-blue-400">exp</span> = <span class="text-amber-300">'15+ years'</span><br/>
                        &nbsp;&nbsp;<span class="text-blue-400">open</span> = <span class="text-green-400">true</span> <span class="text-text-muted/40">// remote</span><br/>
                        <span class="text-text-muted">{`}`}</span>
                    </div>
                </div>
            )}
        </div>
    </Container>
</section>
