---
import Container from '@/components/ui/container.astro'
import Section from '@/components/ui/section.astro'
import { Icons, type IconName } from '@/lib/icons'
import type { HomeContent } from '@/content/home'

interface Props {
    content: HomeContent['philosophy']
}

const { content } = Astro.props
---

<Container>
    <div class="grid lg:grid-cols-2 gap-6 lg:gap-12">
        <div class="flex flex-col items-start justify-center gap-2">
            <h2 class="font-serif text-primary text-4xl md:text-5xl font-bold max-w-xl mb-2">
                {content.title}
            </h2>
            <p class="text-text-muted text-lg leading-relaxed max-w-xl">
                {content.intro}
            </p>
        </div>
        <div class="grid gap-6">
            {
                content.items.map((item) => {
                    const Icon = Icons[item.icon as IconName] || Icons.help
                    return (
                        <div class="flex flex-col lg:flex-row gap-2 lg:gap-4 bg-black/5 border border-primary/10 rounded-2xl shadow-2xl shadow-primary/5 p-8">
                            <div class="shrink-0 w-12 h-12 rounded-xl bg-primary/10 border border-primary/20 flex items-center justify-center text-primary">
                                <Icon class="w-6 h-6" />
                            </div>
                            <div>
                                <h3 class="font-serif text-xl lg:text-2xl font-bold mb-1 text-primary">{item.title}</h3>
                                <p class="text-text-muted leading-relaxed">{item.description}</p>
                            </div>
                        </div>
                    )
                })
            }
        </div>
    </div>
</Container>
