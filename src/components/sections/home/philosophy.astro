---
import Container from '@/components/ui/container.astro'
import Section from '@/components/ui/section.astro'
import { Icons, type IconName } from '@/lib/icons'
import type { HomeContent } from '@/content/home'

interface Props {
    content: HomeContent['philosophy']
}

const { content } = Astro.props
---

<Section>
    <Container>
        <div class='text-center mb-14'>
            <h2 class='font-serif text-4xl md:text-5xl font-bold mb-5'>
                {content.title}
            </h2>
            <p class='text-text-muted text-lg max-w-2xl mx-auto leading-relaxed'>
                {content.intro}
            </p>
        </div>

        <div class='grid md:grid-cols-3 gap-6'>
            {content.items.map((item) => {
                const Icon = Icons[item.icon as IconName] || Icons.help
                return (
                    <div class='group relative bg-bg-card border border-border rounded-2xl p-8 hover:border-primary/40 transition-all duration-300 hover:-translate-y-1'>
                        <div class='w-12 h-12 rounded-xl bg-primary/10 border border-primary/20 flex items-center justify-center text-primary mb-6 group-hover:bg-primary/20 transition-colors duration-300'>
                            <Icon class='w-6 h-6' />
                        </div>
                        <h3 class='font-serif text-xl font-bold mb-3'>{item.title}</h3>
                        <p class='text-text-muted text-sm leading-relaxed'>{item.description}</p>
                        <div class='absolute bottom-0 left-8 right-8 h-px bg-linear-to-r from-transparent via-primary/30 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300' />
                    </div>
                )
            })}
        </div>
    </Container>
</Section>
