---
import Container from "../../ui/container.astro";
import Section from "../../ui/section.astro";
import type { HomeContent } from "../../../content/home";

interface Props {
    content: HomeContent["philosophy"];
}

const { content } = Astro.props;

const icons: Record<string, string> = {
    quality: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>`,
    ownership: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>`,
    team: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>`,
};
---

<Section>
    <Container>
        <div class="text-center mb-14">
            <h2 class="font-serif text-4xl md:text-5xl font-bold mb-5">
                {content.title}
            </h2>
            <p class="text-text-muted text-lg max-w-2xl mx-auto leading-relaxed">
                {content.intro}
            </p>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
            {content.items.map((item, i) => (
                <div class="group relative bg-bg-card border border-border rounded-2xl p-8 hover:border-primary/40 transition-all duration-300 hover:-translate-y-1">
                    <div class="w-12 h-12 rounded-xl bg-primary/10 border border-primary/20 flex items-center justify-center text-primary mb-6 group-hover:bg-primary/20 transition-colors duration-300" set:html={icons[item.icon]} />
                    <h3 class="font-serif text-xl font-bold mb-3">{item.title}</h3>
                    <p class="text-text-muted text-sm leading-relaxed">{item.description}</p>
                    <div class="absolute bottom-0 left-8 right-8 h-px bg-linear-to-r from-transparent via-primary/30 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
                </div>
            ))}
        </div>
    </Container>
</Section>
