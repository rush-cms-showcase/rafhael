---
import Particles from '@/components/ui/particles.astro'
import Container from '@/components/ui/container.astro'
import Button from '@/components/ui/button.astro'
import { Icons } from '@/lib/icons'
import { buildWhatsappUrl } from '@/lib/whatsapp'
import type { LPFastSiteContent } from '@/content/lp-fast-site'

const ArrowRightIcon = Icons['arrow-right']

interface Props {
    content: LPFastSiteContent['hero']
}

const { content } = Astro.props

const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER || '5511999999999' 
const whatsappUrl = buildWhatsappUrl(whatsappNumber, content.whatsappMessage)
---

<section
    class='relative min-h-[90vh] flex items-center pt-32 pb-0 overflow-hidden'
>
    <Particles />

    <div class='absolute inset-0 pointer-events-none'>
        <div
            class='absolute top-0 right-0 w-[60%] h-full bg-[radial-gradient(ellipse_at_70%_30%,var(--color-primary)_0%,transparent_60%)] opacity-10'
        >
        </div>
    </div>

    <Container className='p-0'>
        <div class='grid lg:grid-cols-2 gap-16 items-center'>
            <div class='relative z-10 max-lg:text-center flex flex-col items-start align-center gap-4 lg:mb-32'>
                <h1
                    class='font-serif text-4xl md:text-5xl lg:text-6xl font-bold leading-tight animate-fade-in delay-100'
                    set:html={content.title}
                />

                <p
                    class='text-text-muted text-base md:text-lg lg:text-xl max-w-lg leading-relaxed animate-fade-in delay-200'
                    set:html={content.subtitle}
                />

                <div
                    class='flex max-lg:justify-center flex-wrap gap-4 animate-fade-in-up delay-300'
                >
                    <Button
                        href={whatsappUrl}
                        variant='primary'
                        size='lg'
                        className='shadow-[0_10px_40px_rgba(63,145,240,0.3)] w-full sm:w-auto text-base md:text-lg py-4 md:py-6'
                        target='_blank'
                    >
                        {content.ctaPrimary}
                        <ArrowRightIcon class='w-5 h-5 ml-1' />
                    </Button>
                </div>
            </div>

            <div class='relative z-10 animate-fade-in delay-500 lg:flex justify-end hidden h-full'>
                <div class='relative h-full w-full max-w-xl mx-auto lg:mx-0 flex justify-center items-end'>
                    <div class='absolute inset-0 bg-primary/20 blur-[100px] rounded-full pointer-events-none z-0'></div>
                    <img 
                        src={content.photoUrl} 
                        alt='Rafhael Marsigli' 
                        class='relative z-10 object-contain object-bottom-left w-full h-full scale-110 origin-bottom drop-shadow-2xl'
                    />
                </div>
            </div>
            
            <div class='relative z-10 animate-fade-in delay-500 lg:hidden flex justify-center mt-8'>
                <div class='relative w-full max-w-[280px] sm:max-w-xs mx-auto flex justify-center'>
                    <div class='absolute inset-0 bg-primary/20 blur-[50px] rounded-full pointer-events-none z-0'></div>
                    <img 
                        src={content.photoUrl} 
                        alt='Rafhael Marsigli' 
                        class='relative z-10 object-contain object-bottom w-full h-[350px] drop-shadow-xl'
                    />
                </div>
            </div>
        </div>
    </Container>
</section>
