---
import Container from "../../ui/container.astro";
import Section from "../../ui/section.astro";
import Button from "../../ui/button.astro";
import IconCheck from "~icons/lucide/check";
import IconGift from "~icons/lucide/gift";
import type { LPFastSiteContent } from "../../../content/lp-fast-site";

interface Props {
    content: LPFastSiteContent["pricing"];
}

const { content } = Astro.props;

const cleanNumber = (import.meta.env.PUBLIC_WHATSAPP_NUMBER || "5511999999999").replace(/\D/g, '');
const message = content.whatsappMessage || "Olá! Gostaria de garantir o pacote de Landing Page.";
const defaultWhatsappUrl = `https://wa.me/${cleanNumber}?text=${encodeURIComponent(message)}`;

// If a checkoutUrl is provided (like a Stripe link), use it. Otherwise fallback to WhatsApp.
const buttonHref = content.checkoutUrl && content.checkoutUrl !== "#" ? content.checkoutUrl : defaultWhatsappUrl;
---

<Section class="bg-primary/5 py-24 relative overflow-hidden" id="pricing">
    {/* Decorative blur */}
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-primary/20 blur-[120px] rounded-full pointer-events-none z-0"></div>

    <Container className="relative z-10">
        <div class="text-center max-w-3xl mx-auto mb-16">
            <h2 
                class="font-serif text-3xl md:text-5xl font-bold mb-4"
                set:html={content.title}
            />
            <p 
                class="text-text-muted text-lg md:text-xl"
            >
                {content.subtitle}
            </p>
        </div>

        <div class="max-w-2xl mx-auto">
            <div class="bg-bg-card border-2 border-primary/50 rounded-3xl p-8 md:p-12 shadow-[0_0_50px_rgba(63,145,240,0.15)] relative">
                {/* Ribbon */}
                <div class="absolute top-0 right-8 -translate-y-1/2 bg-primary text-white text-sm font-bold px-4 py-1.5 rounded-full uppercase tracking-wider shadow-lg">
                    Oferta Única
                </div>

                <div class="mb-8">
                    <p class="text-text-muted line-through text-xl mb-1">{content.priceOriginal}</p>
                    <div class="flex items-baseline gap-2 mb-2">
                        <span class="text-5xl md:text-6xl font-bold font-mono text-text-main">
                            {content.price}
                        </span>
                        <span class="text-text-muted font-medium">{content.priceSuffix}</span>
                    </div>
                    <p class="text-sm text-text-muted italic">{content.disclaimer}</p>
                </div>

                <div class="h-px bg-border my-8"></div>

                <ul class="space-y-4 mb-10">
                    {content.features.map(feature => (
                        <li class="flex items-start gap-4">
                            <IconCheck class="w-6 h-6 text-green-500 shrink-0 mt-0.5" />
                            <span class="text-text-main text-lg">{feature}</span>
                        </li>
                    ))}
                    
                    {content.bonuses.map(bonus => (
                        <li class="flex items-start gap-4 bg-primary/10 p-3 rounded-xl border border-primary/20">
                            <IconGift class="w-6 h-6 text-amber-500 shrink-0 mt-0.5" />
                            <span class="text-text-main text-lg font-medium"><span class="text-amber-500 font-bold mr-1">BÔNUS:</span> {bonus}</span>
                        </li>
                    ))}
                </ul>

                <Button
                    href={buttonHref}
                    variant="primary"
                    size="lg"
                    className="w-full justify-center shadow-user-action text-lg py-6"
                    target="_blank"
                >
                    {content.cta}
                </Button>
            </div>
        </div>
    </Container>
</Section>
