---
import Container from '@/components/ui/container.astro'
import Section from '@/components/ui/section.astro'

interface Props {
    content: {
        quote: string
        journey: {
            title: string
            subtitle: string
            text1: string
            text2: string
        }
        philosophy: {
            title: string
            subtitle: string
            text1: string
            text2: string
            text3: string
        }
    }
}

const { content } = Astro.props
---

<Section class='bg-bg-elevated/50 py-16'>
    <Container>
        <div class='max-w-4xl mx-auto'>
            <div class='prose prose-lg prose-invert prose-headings:font-serif prose-headings:font-bold max-w-none'>
                <p class='lead text-2xl mb-12 border-l-4 border-primary pl-6 italic' set:html={content.quote} />
                
                <h2 class='text-4xl mb-8' set:html={content.journey.title} />
                <h3 class='text-xl text-primary font-bold mb-4 uppercase tracking-wider' set:html={content.journey.subtitle} />
                <div class='relative mb-16'>
                    <p class='mb-6 relative z-10 bg-bg-elevated/80 backdrop-blur-sm p-4 rounded-xl' set:html={content.journey.text1} />
                    <p class='mb-6' set:html={content.journey.text2} />
                </div>
            </div>
        </div>

        <div class='max-w-4xl mx-auto'>
            <div class='prose prose-lg prose-invert prose-headings:font-serif prose-headings:font-bold max-w-none'>
                <div class='relative mb-16'>
                    <h2 class='text-4xl mb-8 clear-both pt-12' set:html={content.philosophy.title} />
                    <h3 class='text-xl text-primary font-bold mb-4 uppercase tracking-wider' set:html={content.philosophy.subtitle} />
                    
                    <p class='mb-6' set:html={content.philosophy.text1} />
                    <p class='mb-6' set:html={content.philosophy.text2} />
                    <p set:html={content.philosophy.text3} />
                </div>
            </div>
        </div>
    </Container>
</Section>
