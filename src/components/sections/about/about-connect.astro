---
import Container from '@/components/ui/container.astro'
import Section from '@/components/ui/section.astro'
import { Icons } from '@/lib/icons'

interface Props {
    content: {
        title: string
        text: string
    }
}

const { content } = Astro.props

const LinkedinIcon = Icons.linkedin
const WhatsappIcon = Icons.whatsapp
const TelegramIcon = Icons.telegram

const linkedinUrl = import.meta.env.LINKEDIN_URL ?? 'https://www.linkedin.com/in/rafhael/'
---

<Section class='py-16'>
    <Container className='max-w-3xl'>
        <div class='bg-bg-card border border-border rounded-3xl p-8 lg:p-12 text-center relative overflow-hidden'>
            <div class='absolute top-0 right-0 w-64 h-64 bg-primary/10 rounded-full blur-[80px] -mr-32 -mt-32 pointer-events-none'></div>
            
            <h2 class='font-serif text-3xl font-bold mb-6' set:html={content.title} />
            
            <p class='text-text-muted mb-8 italic' set:html={content.text} />
            
            <div class='flex flex-wrap items-center justify-center gap-4'>
                <a 
                    href={linkedinUrl}
                    target='_blank' 
                    rel='noopener noreferrer'
                    class='flex items-center gap-3 px-6 py-3 bg-[#0077b5] text-white rounded-lg hover:bg-[#006396] transition-all hover:-translate-y-1 shadow-lg shadow-[#0077b5]/20 font-medium'
                >
                    <LinkedinIcon class='w-5 h-5' />
                    LinkedIn
                </a>
                
                <a 
                    href='https://wa.me/5512983173077' 
                    target='_blank' 
                    rel='noopener noreferrer'
                    class='flex items-center gap-3 px-6 py-3 bg-[#25D366] text-white rounded-lg hover:bg-[#128C7E] transition-all hover:-translate-y-1 shadow-lg shadow-[#25D366]/20 font-medium'
                >
                    <WhatsappIcon class='w-5 h-5' />
                    WhatsApp
                </a>
                
                <a 
                    href='https://t.me/rmarsigli' 
                    target='_blank' 
                    rel='noopener noreferrer'
                    class='flex items-center gap-3 px-6 py-3 bg-[#0088cc] text-white rounded-lg hover:bg-[#007dbd] transition-all hover:-translate-y-1 shadow-lg shadow-[#0088cc]/20 font-medium'
                >
                    <TelegramIcon class='w-5 h-5' />
                    Telegram
                </a>
            </div>
        </div>
    </Container>
</Section>
