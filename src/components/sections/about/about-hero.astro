---
import Container from '@/components/ui/container.astro'
import Section from '@/components/ui/section.astro'
import { Icons } from '@/lib/icons'

interface Props {
    content: {
        brow: string
        title: string
        subtitle: string
    }
    linkedinUrl: string
}

const { content, linkedinUrl } = Astro.props
const LinkedinIcon = Icons.linkedin
---

<Section class='relative'>
    <Container>
        <div class='grid lg:grid-cols-2 gap-12 items-center min-h-[60vh]'>
            <div class='relative z-10'>
                <span class='text-primary font-bold tracking-widest uppercase mb-4 block' set:html={content.brow} />
                <h1 class='font-serif text-5xl lg:text-7xl font-bold mb-8 leading-tight' set:html={content.title} />
                <p class='text-xl text-text-muted leading-relaxed max-w-lg mb-8' set:html={content.subtitle} />
                <a
                    href={linkedinUrl}
                    target='_blank'
                    rel='noopener noreferrer'
                    class='inline-flex items-center gap-3 px-6 py-3 bg-[#0077b5] text-white rounded-lg hover:bg-[#006396] transition-all hover:-translate-y-0.5 shadow-lg shadow-[#0077b5]/25 font-medium'
                >
                    <LinkedinIcon class='w-5 h-5' />
                    LinkedIn
                </a>
            </div>
            
            <div class='relative'>
                <div class='absolute top-20 -right-10 md:top-40 md:-right-20 w-64 h-64 md:w-96 md:h-96 bg-primary/20 blur-[60px] md:blur-[100px] rounded-full pointer-events-none'></div>
                <div class='relative z-10 flex justify-center'>
                    <div class='relative rounded-2xl overflow-hidden shadow-2xl border border-white/10 aspect-4/5 max-w-md mx-auto'>
                        <img 
                            src='/rafhael-profile-picture.webp' 
                            alt='Rafhael Marsigli' 
                            class='w-full h-full object-cover'
                        />
                        <div class='absolute bottom-6 left-6 right-6'>
                            <p class='font-serif text-2xl font-bold text-white'>Rafhael Marsigli</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </Container>
</Section>
