---
export interface TestimonialContent {
    quote: string
    author: string
    role: string
}

interface Props {
    content: TestimonialContent
}

const { content } = Astro.props
---

<div class="max-w-4xl mx-auto flex flex-col items-start justify-center gap-2 lg:gap-4">
    <p class="font-serif text-2xl md:text-4xl italic leading-relaxed text-text-main">
        {content.quote}
    </p>
    <span class="w-full h-[1px] bg-primary/5"></span>
    <div class="flex flex-col items-start justify-start">
        <span class="font-bold text-white text-xl font-serif">
            - <span class="text-primary">{content.author}</span>, <span class="text-white/50">{content.role}</span>
        </span>
    </div>
</div>
