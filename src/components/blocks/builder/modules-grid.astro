---
import type { ModulesBlockData } from '@/types/blocks'
import Container from '@/components/ui/container.astro'
import { Icons } from '@/lib/icons'

const SquareCheckIcon = Icons.square_check
const IconInfo = Icons.info

interface Props {
	data: ModulesBlockData
}

const { data } = Astro.props
---

<section>
	<Container>
		<div class="grid grid-cols-2 gap-8 px-4 lg:px-8">
			{data.items.map((item, index) => (
				<div class={`grid gap-4 lg:gap-8 items-center col-span-2 ${item.image ? 'lg:grid-cols-2 lg:mb-16 xl:mb-32' : 'lg:col-span-1 border border-primary/20 rounded-xl p-4 lg:p-8'}`}>
					{item.image && (
						<div class={`bg-black/10 rounded-lg overflow-hidden border-y border border-primary/20 shadow-2xl shadow-primary/5 ${index % 2 !== 0 ? 'lg:order-last' : ''}`}>
							<div class="relative border-b border-primary/20 p-3 flex items-center justify-start gap-1 [&>span]:opacity-70 [&>span]:border [&>span]:rounded-full [&>span]:w-3 [&>span]:h-3">
								<span class="border-red-400"></span>
								<span class="border-yellow-300"></span>
								<span class="border-green-500"></span>
								{item.url && (
									<div class="absolute top-1/2 left-1/2 h-[22px] w-[300px] mt-[-11px] ml-[-150px] flex items-center justify-center bg-primary/10 text-xs rounded-sm border border-primary/20">
										<p class="opacity-50">{item.url}</p>
									</div>
								)}
							</div>
							<img
								class="w-full max-w-full"
								src={item.image}
								alt="Social Media"
								width={1489}
								height={879}
							>
						</div>
					)}
					<div class="flex flex-col items-start justify-center gap-4 lg:gap-6 xl:gap-8">
						<div class="space-y-2">
							<h3 class='font-serif text-primary text-2xl lg:text-4xl xl:text-5xl font-bold'>
								{item.title}
							</h3>
							{item.tag && (
								<div class='inline-flex items-center rounded-md bg-primary/10 border border-primary/20 px-2 py-1 text-xs font-semibold text-primary uppercase tracking-wider'>
									{item.tag}
								</div>
							)}
							<p class='lg:text-lg leading-relaxed'>
								{item.description}
							</p>
						</div>
						<div>
							<ul class='space-y-3'>
								{item.bullets.map((bullet) => (
									<li class='flex justify-start items-center gap-2 lg:text-lg text-text-muted'>
										<SquareCheckIcon class="w-5 h-5" />
										<span>{bullet}</span>
									</li>
								))}
							</ul>
							
							{item.callout && (
								<div class='mt-6 lg:mt-12 text-primary flex items-center max-w-9/10 lg:max-w-4/5 gap-2 lg:gap-4'>
									<IconInfo class="w-8 h-8 lg:w-10 lg:h-10" />
									<p class='italic'>
										{item.callout}
									</p>
								</div>
							)}
						</div>
					</div>
				</div>
			))}
		</div>
	</Container>
</section>
