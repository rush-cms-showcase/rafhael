---
import type { CtaBlockData } from '@/types/blocks'
import Container from '@/components/ui/container.astro'
import Section from '@/components/ui/section.astro'

interface Props {
	data: CtaBlockData
}

const { data } = Astro.props
---

<Section class='py-20 md:py-32 bg-primary/5 border-t border-primary/10 relative overflow-hidden text-center'>
	<Container className='max-w-3xl relative z-10'>
		<h2 class='text-4xl md:text-5xl font-serif font-bold text-text-main mb-6'>{data.heading}</h2>
		<p class='text-lg text-text-muted mb-10 leading-relaxed'>{data.body}</p>

		<div class='flex flex-wrap justify-center gap-4 mb-16'>
			{data.actions.map((action) => (
				<a
					href={action.url}
					class:list={[
						'inline-flex items-center justify-center gap-2 rounded-md px-8 py-4 text-sm font-bold transition-all active:scale-95',
						action.variant === 'primary'
							? 'bg-primary text-white hover:brightness-110 shadow-lg shadow-primary/20'
							: 'border border-border bg-bg-card text-text-main hover:border-primary/40 hover:bg-bg-elevated'
					]}
				>
					{action.label}
				</a>
			))}
		</div>

		{data.quickStart && (
			<div class='max-w-lg mx-auto bg-black/50 border border-border/50 rounded-xl p-6 text-left'>
				<p class='text-sm text-text-muted mb-3'>{data.quickStart.label}</p>
				<pre class='bg-black/50 p-4 rounded-md overflow-x-auto text-primary text-sm font-mono leading-loose'><code>{data.quickStart.code}</code></pre>
				<p class='text-xs text-text-subtle mt-4 italic'>{data.quickStart.caption}</p>
			</div>
		)}
	</Container>
</Section>
