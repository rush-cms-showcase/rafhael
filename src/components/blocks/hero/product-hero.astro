---
import Container from '@/components/ui/container.astro'
import Section from '@/components/ui/section.astro'
import { Icons } from '@/lib/icons'

export interface ProductHeroAction {
	label: string
	icon: keyof typeof Icons
	url: string
	variant?: 'primary' | 'secondary'
}

export interface ProductHeroContent {
	title: string
	accent: string
	tagline: string
  	repoUrl?: string
	actions?: ProductHeroAction[]
	command?: {
		text: string
		icon: keyof typeof Icons
	}
	badges?: string[]
}

interface Props {
	content: ProductHeroContent
}

const { content } = Astro.props
---

<Section class='relative overflow-hidden pt-24 pb-16 text-center'>
	<div
		aria-hidden='true'
		class='pointer-events-none absolute -top-40 left-1/2 h-[600px] w-[900px] -translate-x-1/2 [background:radial-gradient(ellipse_at_center,var(--color-primary),transparent_70%)] opacity-10'
	></div>

	<Container>
		<div class='mx-auto max-w-4xl pt-16'>
			<h1 class='m-0 font-serif text-4xl lg:text-6xl leading-[0.95] tracking-tighter text-text-main'>
				{content.title} <span class='text-primary'>{content.accent}</span>
			</h1>
			<p class='mx-auto mt-8 mb-0 max-w-2xl text-lg md:text-xl leading-relaxed text-text-muted'>
				{content.tagline}
			</p>
			<div class='mt-12 flex flex-wrap justify-center gap-4'>
				{content.actions?.map((action) => {
					const Icon = Icons[action.icon] || Icons.help
					return (
						<a
							href={action.url}
							class:list={[
								'inline-flex items-center gap-2 rounded-md px-6 py-3.5 text-sm font-bold transition-all active:scale-95',
								action.variant === 'primary'
									? 'bg-primary text-white hover:brightness-110 shadow-lg shadow-primary/20'
									: 'border border-border bg-bg-card text-text-main hover:border-primary/40 hover:bg-bg-elevated'
							]}
						>
							<Icon class='size-4' />
							{action.label}
						</a>
					)
				})}
			</div>

			{content.badges && content.badges.length > 0 && (
				<div class='mt-10 flex flex-wrap justify-center gap-3'>
					{content.badges.map((badge, i) => (
						<span class:list={[
							'inline-flex items-center gap-2 rounded-md border px-3.5 py-1.5 font-mono text-xs uppercase tracking-wider',
							i === 0
								? 'border-primary/10 bg-primary/5 text-primary'
								: 'border-border/50 bg-bg-elevated/50 text-text-subtle'
						]}>
							{i === 0 && <span class='size-1.5 rounded-full bg-primary animate-pulse'></span>}
							{badge}
						</span>
					))}
				</div>
			)}
		</div>
	</Container>
</Section>
