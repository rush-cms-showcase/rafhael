---
import { Icons } from '@/lib/icons'
import { buildWhatsappUrl } from '@/lib/whatsapp'

const WhatsappIcon = Icons.whatsapp

interface Props {
    whatsappNumber?: string;
    message?: string;
}

const { 
    whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER || "5511999999999", 
    message = "Olá! Gostaria de ter um site rápido e de alta conversão." 
} = Astro.props;

const href = buildWhatsappUrl(whatsappNumber, message);
---

<a 
    href={href}
    target="_blank"
    rel="noopener noreferrer"
    class="fixed bottom-6 right-6 z-50 flex items-center justify-center w-14 h-14 bg-[#25D366] text-white rounded-full shadow-lg hover:shadow-2xl hover:-translate-y-1 transition-all duration-300"
    aria-label="Fale conosco no WhatsApp"
>
    <WhatsappIcon class='w-8 h-8' />
</a>
