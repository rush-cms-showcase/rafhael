---
import { calculateReadingTime } from '@/lib/post-utils'
import { formatDate } from '@/lib/date-utils'
import { Icons } from '@/lib/icons'
import type { BlogPost } from '@/lib/rush'

const ClockIcon = Icons.clock
const CalendarIcon = Icons.calendar
const ArrowRightIcon = Icons.arrow_right

interface Props {
    post: BlogPost
    locale: 'en' | 'pt_BR'
    basePrefix: string
    catSlug: string
    readMoreLabel: string
}

const { post, locale, basePrefix, catSlug, readMoreLabel } = Astro.props

const hasImage = !!post.featured_image
const readingTime = calculateReadingTime(post, locale)
const date = post.published_at ? formatDate(post.published_at, locale) : ''
---

<article
    class={`group flex flex-col bg-bg-card border border-primary/10 rounded-2xl overflow-hidden hover:border-primary/50 transition-all duration-300 hover:-translate-y-1 ${!hasImage ? 'animate-fade-in' : ''}`}>
    {
        hasImage && post.featured_image && (
            <div class="relative aspect-video overflow-hidden block">
                <a href={`${basePrefix}/blog/${post.slug}`} class="block w-full h-full">
                    <img
                        src={post.featured_image.preview || post.featured_image.url}
                        alt={post.title}
                        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                        loading="lazy"
                    />
                </a>
                {post.categories && post.categories.length > 0 && (
                    <div class="absolute top-4 left-4 flex flex-wrap gap-2 z-10">
                        {post.categories.map((cat) => (
                            <a
                                href={`${basePrefix}/${catSlug}/${cat.slug}`}
                                class="inline-flex items-center rounded px-3 py-1 text-xs font-medium bg-black/75 border border-primary/50 text-white shadow-lg hover:bg-primary hover:shadow-lg transition-colors">
                                {cat.name}
                            </a>
                        ))}
                    </div>
                )}
            </div>
        )
    }

    <div class={`flex-1 p-6 flex flex-col ${!hasImage ? 'justify-center' : ''}`}>
        {
            !hasImage && post.categories && post.categories.length > 0 && (
                <div class="mb-4 flex flex-wrap gap-2">
                    {post.categories.map((cat) => (
                        <a
                            href={`${basePrefix}/${catSlug}/${cat.slug}`}
                            class="inline-flex items-center rounded px-3 py-1 text-xs font-medium bg-primary/10 text-primary border border-primary/20 hover:bg-primary/20 transition-colors">
                            {cat.name}
                        </a>
                    ))}
                </div>
            )
        }

        <a href={`${basePrefix}/blog/${post.slug}`} class="group-hover:text-primary transition-colors block">
            <h3
                class={`font-serif font-bold mb-3 leading-tight group-hover:underline ${hasImage ? 'text-2xl' : 'text-3xl md:text-4xl'}`}>
                {post.title}
            </h3>
        </a>

        <div class="flex items-center justify-between pt-6 mt-auto">
            <div class="flex items-center gap-4 text-xs font-medium text-text-muted">
                <div class="flex items-center gap-1.5">
                    <ClockIcon class="w-4 h-4" />
                    <span>{readingTime}</span>
                </div>

                {
                    date && (
                        <div class="flex items-center gap-1.5">
                            <CalendarIcon class="w-4 h-4" />
                            <span>{date}</span>
                        </div>
                    )
                }
            </div>

            <a
                href={`${basePrefix}/blog/${post.slug}`}
                class="text-sm font-bold text-primary flex items-center gap-1 group/link">
                {readMoreLabel}
                <ArrowRightIcon class="w-4 h-4 transition-transform group-hover/link:translate-x-1" />
            </a>
        </div>
    </div>
</article>
