---
import { calculateReadingTime } from '@/lib/post-utils'
import { formatDate } from '@/lib/date-utils'
import { Icons } from '@/lib/icons'
import type { BlogPost } from '@/lib/rush'

const ClockIcon = Icons.clock
const CalendarIcon = Icons.calendar
const ArrowRightIcon = Icons.arrow_right
const ChevronLeftIcon = Icons.chevron_left
const ChevronRightIcon = Icons.chevron_right

interface Props {
    initialPosts: BlogPost[]
    categories?: { name: string; slug: string }[]
    labels: {
        readMore: string
        allCategories: string
        previous?: string
        next?: string
    }
    locale?: 'en' | 'pt_BR'
    taxonomies?: {
        category: { label: string; slug: string }
        tag: { label: string; slug: string }
    }
    pagination?: {
        currentPage: number
        lastPage: number
        url: {
            prev?: string
            next?: string
        }
    }
}

const { initialPosts, categories, labels, locale = 'en', taxonomies, pagination } = Astro.props

const basePrefix = locale === 'pt_BR' ? '/br' : ''
const catSlug = taxonomies?.category.slug || 'category'
const prevLabel = labels.previous || (locale === 'pt_BR' ? 'Anterior' : 'Previous')
const nextLabel = labels.next || (locale === 'pt_BR' ? 'Próxima' : 'Next')
---

<div class='w-full'>
    <div class='flex flex-wrap justify-center gap-3 mb-12 animate-fade-in'>
        <a
            href={`${basePrefix}/blog`}
            class='px-4 py-2 rounded-full text-sm font-medium transition-colors bg-primary text-white shadow-lg'
        >
            {labels.allCategories}
        </a>
        {categories && categories.map((cat) => (
            <a
                href={`${basePrefix}/${catSlug}/${cat.slug}`}
                class='px-4 py-2 rounded-full text-sm font-medium transition-colors bg-bg-elevated text-text-muted hover:bg-bg-elevated/80 hover:text-primary border border-border'
            >
                {cat.name}
            </a>
        ))}
    </div>

    <div class='grid md:grid-cols-2 lg:grid-cols-3 gap-8 animate-fade-in'>
        {initialPosts.map((post) => {
            const hasImage = !!post.featured_image;
            const readingTime = calculateReadingTime(post, locale);
            const date = post.published_at ? formatDate(post.published_at, locale) : "";
            
            return (
                <article class={`group flex flex-col bg-bg-card border border-border rounded-2xl overflow-hidden hover:border-primary/50 transition-all duration-300 hover:-translate-y-1 ${!hasImage ? 'animate-fade-in' : ''}`}>
                    {hasImage && post.featured_image && (
                        <div class='relative aspect-video overflow-hidden block'>
                            <a href={`${basePrefix}/blog/${post.slug}`} class='block w-full h-full'>
                                <img
                                    src={post.featured_image.preview || post.featured_image.url}
                                    alt={post.title}
                                    class='w-full h-full object-cover transition-transform duration-500 group-hover:scale-105'
                                    loading='lazy'
                                />
                            </a>
                            {post.categories && post.categories.length > 0 && (
                                <div class='absolute top-4 left-4 flex flex-wrap gap-2 z-10'>
                                    {post.categories.map((cat) => (
                                        <a 
                                            href={`${basePrefix}/${catSlug}/${cat.slug}`}
                                            class='inline-flex items-center rounded px-3 py-1 text-xs font-medium bg-primary text-white shadow-lg hover:bg-primary-dark transition-colors'
                                        >
                                            {cat.name}
                                        </a>
                                    ))}
                                </div>
                            )}
                        </div>
                    )}

                    <div class={`flex-1 p-6 flex flex-col ${!hasImage ? 'justify-center' : ''}`}>
                        {!hasImage && post.categories && post.categories.length > 0 && (
                            <div class='mb-4 flex flex-wrap gap-2'>
                                {post.categories.map((cat) => (
                                    <a
                                        href={`${basePrefix}/${catSlug}/${cat.slug}`} 
                                        class='inline-flex items-center rounded px-3 py-1 text-xs font-medium bg-primary/10 text-primary border border-primary/20 hover:bg-primary/20 transition-colors'
                                    >
                                        {cat.name}
                                    </a>
                                ))}
                            </div>
                        )}

                        <a
                            href={`${basePrefix}/blog/${post.slug}`}
                            class='group-hover:text-primary transition-colors block'
                        >
                            <h3 class={`font-serif font-bold mb-3 leading-tight ${hasImage ? 'text-2xl' : 'text-3xl md:text-4xl'}`}>
                                {post.title}
                            </h3>
                        </a>

                        <div class='flex items-center justify-between pt-6 mt-auto'>
                            <div class='flex items-center gap-4 text-xs font-medium text-text-muted'>
                                <div class='flex items-center gap-1.5'>
                                    <ClockIcon class='w-4 h-4' />
                                    <span>{readingTime}</span>
                                </div>
                                
                                {date && (
                                    <div class='flex items-center gap-1.5'>
                                        <CalendarIcon class='w-4 h-4' />
                                        <span>{date}</span>
                                    </div>
                                )}
                            </div>

                            <a
                                href={`${basePrefix}/blog/${post.slug}`}
                                class='text-sm font-bold text-primary flex items-center gap-1 group/link'
                            >
                                {labels.readMore}
                                <ArrowRightIcon class='w-4 h-4 transition-transform group-hover/link:translate-x-1' />
                            </a>
                        </div>
                    </div>
                </article>
            );
        })}
    </div>
    
    {pagination && pagination.lastPage > 1 && (
        <div class='flex justify-center gap-4 mt-16 animate-fade-in-up'>
            {pagination.url.prev && (
                <a 
                    href={pagination.url.prev}
                    class='flex items-center gap-2 px-6 py-3 rounded-full bg-bg-elevated border border-border hover:border-primary hover:text-primary transition-all font-medium'
                >
                    <ChevronLeftIcon class='w-5 h-5' />
                    {prevLabel}
                </a>
            )}
            
            <span class='flex items-center px-4 font-serif font-bold text-text-muted'>
                {pagination.currentPage} / {pagination.lastPage}
            </span>
            
            {pagination.url.next && (
                <a 
                    href={pagination.url.next}
                    class='flex items-center gap-2 px-6 py-3 rounded-full bg-bg-elevated border border-border hover:border-primary hover:text-primary transition-all font-medium'
                >
                    {nextLabel}
                    <ChevronRightIcon class='w-5 h-5' />
                </a>
            )}
        </div>
    )}
</div>
