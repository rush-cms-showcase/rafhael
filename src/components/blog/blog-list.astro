---
import { Icons } from '@/lib/icons'
import type { BlogPost } from '@/lib/rush'
import BlogCard from '@/components/blog/blog-card.astro'

const ChevronLeftIcon = Icons.chevron_left
const ChevronRightIcon = Icons.chevron_right

interface Props {
    initialPosts: BlogPost[]
    categories?: { name: string; slug: string }[]
    labels: {
        readMore: string
        allCategories: string
        previous?: string
        next?: string
    }
    locale?: 'en' | 'pt_BR'
    taxonomies?: {
        category: { label: string; slug: string }
        tag: { label: string; slug: string }
    }
    pagination?: {
        currentPage: number
        lastPage: number
        url: {
            prev?: string
            next?: string
        }
    }
}

const { initialPosts, categories, labels, locale = 'en', taxonomies, pagination } = Astro.props

const basePrefix = locale === 'pt_BR' ? '/br' : ''
const catSlug = taxonomies?.category.slug || 'category'
const prevLabel = labels.previous || (locale === 'pt_BR' ? 'Anterior' : 'Previous')
const nextLabel = labels.next || (locale === 'pt_BR' ? 'Próxima' : 'Next')
---

<div class="w-full">
    <div class="flex flex-wrap justify-center gap-3 mb-12 animate-fade-in">
        <a
            href={`${basePrefix}/blog`}
            class="px-4 py-2 rounded-full text-sm font-medium transition-colors bg-primary text-white shadow-lg">
            {labels.allCategories}
        </a>
        {
            categories &&
                categories.map((cat) => (
                    <a
                        href={`${basePrefix}/${catSlug}/${cat.slug}`}
                        class="px-4 py-2 rounded-full text-sm font-medium transition-colors bg-bg-elevated text-text-muted hover:bg-bg-elevated/80 hover:text-primary border border-border">
                        {cat.name}
                    </a>
                ))
        }
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 animate-fade-in">
        {
            initialPosts.map((post) => (
                <BlogCard
                    post={post}
                    locale={locale as 'en' | 'pt_BR'}
                    basePrefix={basePrefix}
                    catSlug={catSlug}
                    readMoreLabel={labels.readMore}
                />
            ))
        }
    </div>

    {
        pagination && pagination.lastPage > 1 && (
            <div class="flex justify-center gap-4 mt-16 animate-fade-in-up">
                {pagination.url.prev && (
                    <a
                        href={pagination.url.prev}
                        class="flex items-center gap-2 px-6 py-3 rounded-full bg-bg-elevated border border-border hover:border-primary hover:text-primary transition-all font-medium">
                        <ChevronLeftIcon class="w-5 h-5" />
                        {prevLabel}
                    </a>
                )}

                <span class="flex items-center px-4 font-serif font-bold text-text-muted">
                    {pagination.currentPage} / {pagination.lastPage}
                </span>

                {pagination.url.next && (
                    <a
                        href={pagination.url.next}
                        class="flex items-center gap-2 px-6 py-3 rounded-full bg-bg-elevated border border-border hover:border-primary hover:text-primary transition-all font-medium">
                        {nextLabel}
                        <ChevronRightIcon class="w-5 h-5" />
                    </a>
                )}
            </div>
        )
    }
</div>
