---
import { Icons } from '@/lib/icons'

const TwitterXIcon = Icons.twitter_x
const LinkedinIcon = Icons.linkedin
const WhatsappIcon = Icons.whatsapp
const CopyIcon = Icons.copy
const CheckIcon = Icons.check

interface Props {
	url: string
	title: string
	className?: string
}

const { url, title, className = '' } = Astro.props
---

<div class={`flex items-center gap-2 ${className}`}>
	<button
		type='button'
		class='share-btn w-9 h-9 rounded-full bg-bg-elevated hover:bg-bg-elevated/80 border border-border flex items-center justify-center transition-colors'
		data-platform='twitter'
		data-url={url}
		data-text={title}
		aria-label='Compartilhar no Twitter'
	>
		<TwitterXIcon class='w-4 h-4' />
	</button>
	<button
		type='button'
		class='share-btn w-9 h-9 rounded-full bg-bg-elevated hover:bg-bg-elevated/80 border border-border flex items-center justify-center transition-colors'
		data-platform='linkedin'
		data-url={url}
		aria-label='Compartilhar no LinkedIn'
	>
		<LinkedinIcon class='w-4 h-4' />
	</button>
	<button
		type='button'
		class='share-btn w-9 h-9 rounded-full bg-bg-elevated hover:bg-bg-elevated/80 border border-border flex items-center justify-center transition-colors'
		data-platform='whatsapp'
		data-url={url}
		data-text={title}
		aria-label='Compartilhar no WhatsApp'
	>
		<WhatsappIcon class='w-4 h-4' />
	</button>
	<button
		type='button'
		class='copy-url-btn w-9 h-9 rounded-full bg-bg-elevated hover:bg-bg-elevated/80 border border-border flex items-center justify-center transition-colors'
		data-url={url}
		aria-label='Copiar link'
	>
		<span class='copy-url-icon'>
			<CopyIcon class='w-4 h-4' />
		</span>
		<span class='check-icon hidden'>
			<CheckIcon class='w-4 h-4' />
		</span>
	</button>
</div>

<script>
	document.querySelectorAll('.share-btn').forEach((btn) => {
		btn.addEventListener('click', () => {
			const platform = btn.getAttribute('data-platform')
			const url = btn.getAttribute('data-url')
			const text = btn.getAttribute('data-text')

			const urls = {
				twitter: `https://twitter.com/intent/tweet?url=${encodeURIComponent(url as string)}&text=${encodeURIComponent(text as string)}`,
				linkedin: `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url as string)}`,
				whatsapp: `https://api.whatsapp.com/send?text=${encodeURIComponent(`${text} ${url}`)}`
			}

			window.open(
				urls[platform as keyof typeof urls],
				'_blank',
				'width=600,height=400'
			)
		})
	})

	document.querySelectorAll('.copy-url-btn').forEach((btn) => {
		btn.addEventListener('click', async () => {
			const url = btn.getAttribute('data-url')
			if (!url) return

			try {
				await navigator.clipboard.writeText(url)

				const copyIcon = btn.querySelector('.copy-url-icon')
				const checkIcon = btn.querySelector('.check-icon')

				copyIcon?.classList.add('hidden')
				checkIcon?.classList.remove('hidden')

				setTimeout(() => {
					copyIcon?.classList.remove('hidden')
					checkIcon?.classList.add('hidden')
				}, 2000)
			} catch (err) {
				console.error('Falha ao copiar URL:', err)
			}
		})
	})
</script>
