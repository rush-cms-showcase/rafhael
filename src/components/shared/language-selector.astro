---
import { Icons } from '@/lib/icons'

const GlobeIcon = Icons.globe
const ChevronDownIcon = Icons.chevron_down

interface Props {
  currentLocale: string
  isMobile?: boolean
  ptHref?: string
  enHref?: string
}

const { 
  currentLocale, 
  isMobile = false,
  ptHref = '/br',
  enHref = '/'
} = Astro.props
---

{isMobile ? (
  <div class='flex items-center gap-4 justify-center'>
      <a
        href={enHref}
        data-lang='en'
        class={`language-link px-4 py-2 rounded-lg transition-colors border ${
          currentLocale === 'en' 
            ? 'bg-primary text-white border-primary' 
            : 'text-text-muted border-white/10 hover:border-white/30'
        }`}
      >
        <span class='font-bold text-sm'>EN</span>
      </a>
      <a
        href={ptHref}
        data-lang='pt'
        class={`language-link px-4 py-2 rounded-lg transition-colors border ${
          currentLocale === 'pt_BR' 
            ? 'bg-primary text-white border-primary' 
            : 'text-text-muted border-white/10 hover:border-white/30'
        }`}
      >
        <span class='font-bold text-sm'>BR</span>
      </a>
  </div>
) : (
<div class='relative group z-50'>
  <button
    class='flex items-center gap-2 text-text-muted hover:text-text-main transition-colors text-sm font-medium py-2'
    aria-label='Select Language'
  >
    <GlobeIcon class='w-4 h-4' />
    <span class='uppercase'>{currentLocale === 'pt_BR' ? 'BR' : 'EN'}</span>
    <ChevronDownIcon class='w-3.5 h-3.5 group-hover:rotate-180 transition-transform' />
  </button>

  <div
    class='absolute right-0 top-full mt-2 w-24 py-2 bg-bg-elevated border border-white/10 rounded-lg shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform origin-top-right'
  >
    <a
      href={enHref}
      data-lang='en'
      class={`language-link flex items-center gap-3 px-4 py-2 text-sm hover:bg-white/5 transition-colors ${
        currentLocale === 'en' ? 'text-primary' : 'text-text-muted'
      }`}
    >
      <span class='font-medium'>EN</span>
    </a>
    <a
      href={ptHref}
      data-lang='pt'
      class={`language-link flex items-center gap-3 px-4 py-2 text-sm hover:bg-white/5 transition-colors ${
        currentLocale === 'pt_BR' ? 'text-primary' : 'text-text-muted'
      }`}
    >
      <span class='font-medium'>BR</span>
    </a>
  </div>
  </div>
)}
</div>

<script is:inline>
  document.querySelectorAll('.language-link').forEach(link => {
    link.addEventListener('click', (e) => {
      const lang = e.currentTarget.getAttribute('data-lang');
      if (lang) {
        localStorage.setItem('rush_lang_pref', lang);
      }
    });
  });
</script>
