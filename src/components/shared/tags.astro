---
interface Tag {
    name: string
    slug: string
}

interface Props {
    tags: Tag[]
    basePath: string
    title?: string
    class?: string
    [key: string]: any
}

const { tags, basePath, title = 'Tags', class: className = '', ...rest } = Astro.props

if (!tags || tags.length === 0) {
    return null;
}
---

<div class:list={[className]} {...rest}>
    {title && <h3 class='text-sm uppercase tracking-widest text-text-muted mb-4 font-bold'>{title}</h3>}
    <div class='flex flex-wrap gap-2'>
        {tags.map((tag) => (
            <a href={`${basePath}/${tag.slug}`} class='px-3 py-1 bg-bg-elevated border border-border rounded-lg text-sm text-text-subtle hover:text-primary hover:border-primary/30 transition-colors cursor-pointer'>
                {tag.name}
            </a>
        ))}
    </div>
</div>
