---
import Container from '@/components/ui/container.astro'
import Button from '@/components/ui/button.astro'
import LanguageSelector from '@/components/shared/language-selector.astro'
import GlobalSearchDialog from '@/components/ui/global-search-dialog.astro'
import HeaderLogo from '@/components/layout/header-logo.astro'
import HeaderNav from '@/components/layout/header-nav.astro'
import MobileMenu from '@/components/layout/mobile-menu.astro'
import { Icons } from '@/lib/icons'

const SearchIcon = Icons.search

export interface NavContent {
    about: string
    openSource: string
    cases: string
    blog: string
    login: string
    contact: string
}

interface Props {
    content?: NavContent
    locale?: 'en' | 'pt_BR'
    variant?: 'default' | 'minimal'
    position?: 'fixed' | 'absolute'
}

const { content, locale = 'pt_BR', variant = 'default', position = 'fixed' } = Astro.props
const homeUrl = locale === 'pt_BR' ? '/br' : '/'

const navItems = content ? [
    { label: content.about, href: locale === 'pt_BR' ? '/br/sobre-mim' : '/about-me' },
    { label: content.openSource, href: `${homeUrl === '/' ? '' : homeUrl}/open-source` },
    { label: content.cases, href: `${homeUrl === '/' ? '' : homeUrl}/cases` },
    { label: content.blog, href: `${homeUrl === '/' ? '' : homeUrl}/blog` },
] : []

const searchLabels = {
    placeholder: locale === 'pt_BR' ? 'Buscar artigos...' : 'Search articles...',
    emptyTitle: locale === 'pt_BR' ? 'Nenhum artigo encontrado' : 'No articles found',
    emptyText: locale === 'pt_BR' ? 'Tente outros termos.' : 'Try other terms.',
    initialText: locale === 'pt_BR' ? 'Digite para buscar em todos os artigos' : 'Type to search across all articles',
    loadingText: locale === 'pt_BR' ? 'Carregando índice...' : 'Loading index...'
}
---

<header
    class={`${position} top-0 left-0 right-0 z-50 py-5 bg-bg/95 backdrop-blur-md border-b border-border/50 transition-all duration-300`}
>
    <Container className='flex justify-between items-center'>
        <HeaderLogo homeUrl={homeUrl} />

        {variant !== "minimal" && (
            <HeaderNav items={navItems} />
        )}

        <div class={`flex items-center gap-4 ${variant === "minimal" ? "ml-auto" : ""}`}>
            {variant !== "minimal" && (
                <button
                    id='search-trigger'
                class='flex items-center justify-center w-10 h-10 text-text-muted hover:text-primary transition-colors hover:bg-bg-elevated rounded-lg group relative'
                aria-label='Search'
            >
                <SearchIcon class='w-5 h-5' />
                <span class='absolute -top-1.5 -right-1.5 flex h-4 w-6 items-center justify-center rounded bg-bg-elevated/90 border border-border/50 text-[9px] font-bold text-text-muted shadow-sm backdrop-blur-sm group-hover:border-primary/50 group-hover:text-primary transition-colors pointer-events-none'>
                    ⌘ K
                </span>
                </button>
            )}
            
            {variant !== "minimal" && (
                <GlobalSearchDialog locale={locale} labels={searchLabels} />
            )}

            <div class={variant === "minimal" ? "px-2" : "hidden lg:block px-2"}>
                <LanguageSelector 
                    currentLocale={locale} 
                    enHref={variant === "minimal" ? "/fast-website" : "/"} 
                    ptHref={variant === "minimal" ? "/br/site-rapido" : "/br"} 
                />
            </div>
            
            {variant !== "minimal" && content && (
                <Button
                href={locale === "pt_BR" ? "/br/contato" : "/contact"}
                variant='primary'
                size='md'
                className='hidden md:flex shadow-lg shadow-primary/20'
            >
                <span>{content.contact}</span>
            </Button>
            )}

            {variant !== "minimal" && (
                <MobileMenu items={navItems} locale={locale} contactLabel={content?.contact || ''} />
            )}
        </div>
    </Container>
</header>

<script is:inline>
    (function() {
        const searchTrigger = document.getElementById("search-trigger");
        if (searchTrigger) {
            searchTrigger.addEventListener("click", () => {
                 window.dispatchEvent(new CustomEvent("open-global-search"));
            });
        }
    })();
</script>
