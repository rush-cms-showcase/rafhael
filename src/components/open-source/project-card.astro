---
import type { ProjectMeta } from '@/lib/open-source'
import { Icons } from '@/lib/icons'

interface Props extends ProjectMeta {
	locale: 'en' | 'pt_BR'
}

const { slug, title, description, logo, locale } = Astro.props

const url = locale === 'pt_BR' ? `/br/open-source/${slug}` : `/open-source/${slug}`
const label = locale === 'pt_BR' ? 'Ver projeto' : 'View project'
const cardLabel = locale === 'pt_BR' ? 'Codigo aberto' : 'Open Source'
const initials = title
	.split(' ')
	.filter(Boolean)
	.slice(0, 2)
	.map(word => word[0])
	.join('')
	.toUpperCase()

const ArrowRightIcon = Icons.arrow_right
---

<a
	href={url}
	class='group relative isolate block h-full overflow-hidden rounded-2xl border border-border/80 bg-bg-card/80 p-4 sm:p-5 lg:p-6 xl:p-7
		transition-all duration-300 hover:-translate-y-1 hover:border-primary/40 hover:bg-bg-elevated/90 hover:shadow-2xl hover:shadow-primary/10
		focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/60 focus-visible:ring-offset-2 focus-visible:ring-offset-bg'
>
	<div
		aria-hidden='true'
		class='pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_15%_15%,var(--color-primary),transparent_48%)] opacity-[0.08] transition-opacity duration-300 group-hover:opacity-[0.14]'
	></div>

	<div class='relative z-10 flex h-full flex-col gap-5 lg:gap-6'>
		<div class='flex items-center gap-4 lg:gap-5'>
			{logo ? (
				<div class='shrink-0 h-16 w-16 sm:h-20 sm:w-20 lg:h-24 lg:w-24 rounded-2xl bg-bg/60 shadow-lg overflow-hidden'>
					<img
						src={logo}
						alt={title}
						class='h-full w-full object-cover'
						loading='lazy'
					/>
				</div>
			) : (
				<div class='shrink-0 flex h-16 w-16 sm:h-20 sm:w-20 lg:h-24 lg:w-24 items-center justify-center rounded-2xl border border-primary/25 bg-primary/10 font-mono text-lg font-bold text-primary lg:text-2xl'>
					{initials}
				</div>
			)}

			<h2 class='font-serif text-2xl sm:text-3xl lg:text-[2.1rem] xl:text-[2.4rem] font-bold leading-[1.08] tracking-tight text-text-main transition-colors duration-300 group-hover:text-primary'>
				{title}
			</h2>
		</div>

		<p class='text-sm sm:text-base leading-relaxed text-text-muted'>
			{description}
		</p>

		<div class='mt-auto flex items-center justify-between pt-1'>
			<span class='inline-flex py-2 px-4 gap-2 items-center justify-center rounded-full border border-border bg-bg/70 text-text-muted transition-all duration-300 group-hover:border-primary/40 group-hover:text-primary group-hover:translate-x-1'>
				{label}
				<ArrowRightIcon class='h-4 w-4' />
			</span>
		</div>
	</div>
</a>
