---
import Layout from '@/layouts/layout.astro'
import Header from '@/components/layout/header.astro'
import Footer from '@/components/layout/footer.astro'
import Section from '@/components/ui/section.astro'
import Container from '@/components/ui/container.astro'
import { tiptapToHtml } from '@/lib/blocks/tiptap-to-html'
import { renderMarkdown } from '@/lib/markdown-renderer'
import { unified } from 'unified'
import rehypeParse from 'rehype-parse'
import rehypeExpressiveCode from 'rehype-expressive-code'
import rehypeStringify from 'rehype-stringify'
import Share from '@/components/shared/share.astro'
import Meta from '@/components/shared/meta.astro'
import Categories from '@/components/shared/categories.astro'
import Tags from '@/components/shared/tags.astro'
import { type BlogPost } from '@/lib/rush'
import { homeContent } from '@/content/home'
import { formatDate } from '@/lib/date-utils'
import { calculateReadingTime } from '@/lib/post-utils'

interface Props {
    post: BlogPost
    locale: 'en' | 'pt_BR'
}

const { post, locale } = Astro.props

const content = homeContent[locale]

const title = `${post.title} - Rafhael Marsigli`
const description =
    post.excerpt || (locale === 'en' ? `Read about ${post.title} on the blog.` : `Leia sobre ${post.title} no blog.`)
const image = post.featured_image?.url || '/banner.webp'

const urlPath = locale === 'pt_BR' ? `/br/blog/${post.slug}` : `/blog/${post.slug}`
const url = new URL(urlPath, Astro.site || 'https://rafhael.pro').toString()

let rawMarkdown = post.data?.markdown
let htmlContent = ''

if (rawMarkdown && typeof rawMarkdown === 'string') {
    htmlContent = await renderMarkdown(rawMarkdown)
} else if (post.data?.content || post.content) {
    const doc = Array.isArray(post.data?.content) ? { content: post.data.content } : post.data?.content || post.content

    const rendered = tiptapToHtml(doc as any)
    if (rendered) {
        try {
            const processed = await unified()
                .use(rehypeParse, { fragment: true })
                .use(rehypeExpressiveCode, {
                    themes: ['github-dark'],
                    useThemedScrollbars: false,
                    styleOverrides: { borderRadius: '0.75rem', uiFontFamily: 'inherit' },
                })
                .use(rehypeStringify)
                .process(rendered)

            htmlContent = String(processed)
        } catch (e) {
            console.error('Error processing tiptap with expressive-code:', e)
            htmlContent = rendered
        }
    }
}
---

<Layout title={title} description={description} image={image} lang={locale === 'pt_BR' ? 'pt-BR' : 'en'}>
    <Header content={content.global.nav} locale={locale} />

    <main class="py-24 mt-4 lg:mt-16">
        <article class="space-y-4">
            <Container className="relative max-w-4xl space-y-4 lg:space-y-6">
                <Meta
                    readingTime={calculateReadingTime(post, locale)}
                    publishedAt={post.published_at}
                    locale={locale}
                    class="border-b border-white/2 pb-6 lg:pb-8"
                />
                <h1 class="font-serif text-primary text-4xl md:text-5xl lg:text-6xl font-bold leading-tight">
                    {post.title}
                </h1>
                <Categories
                    categories={post.categories}
                    basePath={locale === 'pt_BR' ? `/br/${content.taxonomies.category.slug}` : '/category'}
                />
                <Share url={url} title={post.title} locale={locale} class="lg:hidden" />
            </Container>
            <Container className="relative max-w-4xl">
                <div class="hidden lg:block absolute top-0 bottom-0 -left-20 w-16">
                    <Share
                        url={url}
                        title={post.title}
                        locale={locale}
                        class="sticky top-32 flex-col border border-primary/10 bg-black/5 gap-4 rounded-3xl p-4"
                    />
                </div>

                {
                    post.featured_image && (
                        <div class="rounded-3xl overflow-hidden shadow-2xl">
                            <img
                                src={post.featured_image.preview || post.featured_image.url}
                                alt={post.title}
                                width="896"
                                height="504"
                                class="w-full h-auto"
                                fetchpriority="high"
                                decoding="async"
                            />
                        </div>
                    )
                }

                <div
                    class="prose prose-invert prose-lg lg:prose-xl max-w-none prose-headings:font-serif prose-headings:font-bold prose-headings:text-primary prose-a:text-primary prose-a:no-underline hover:prose-a:underline prose-img:rounded-2xl">
                    <div set:html={htmlContent} />
                </div>

                <Tags
                    tags={post.tags}
                    basePath={locale === 'pt_BR' ? `/br/${content.taxonomies.tag.slug}` : '/tag'}
                    class="pt-6 border-t border-border/30"
                />
            </Container>
        </article>
    </main>

    <Footer content={content.global.footer} />
</Layout>
