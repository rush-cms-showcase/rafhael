---
import Layout from '@/layouts/layout.astro'
import Header from '@/components/layout/header.astro'
import Footer from '@/components/layout/footer.astro'
import Section from '@/components/ui/section.astro'
import Container from '@/components/ui/container.astro'
import { tiptapToHtml } from '@/lib/blocks/tiptap-to-html'
import { renderMarkdown } from '@/lib/markdown-renderer'
import { unified } from 'unified'
import rehypeParse from 'rehype-parse'
import rehypeExpressiveCode from 'rehype-expressive-code'
import rehypeStringify from 'rehype-stringify'
import { type BlogPost } from '@/lib/rush'
import { homeContent } from '@/content/home'
import { formatDate } from '@/lib/date-utils'
import { calculateReadingTime } from '@/lib/post-utils'

interface Props {
	post: BlogPost
	locale: 'en' | 'pt_BR'
}

const { post, locale } = Astro.props

const content = homeContent[locale]

const title = `${post.title} - Rafhael Marsigli`
const description = post.excerpt || (locale === 'en' ? `Read about ${post.title} on the blog.` : `Leia sobre ${post.title} no blog.`)
const image = post.featured_image?.url || '/banner.webp'

const urlPath = locale === 'pt_BR' ? `/br/blog/${post.slug}` : `/blog/${post.slug}`
const url = new URL(urlPath, Astro.site || 'https://rafhael.pro').toString()

let rawMarkdown = post.data?.markdown
let htmlContent = ''

if (rawMarkdown && typeof rawMarkdown === 'string') {
    htmlContent = await renderMarkdown(rawMarkdown)
} else if (post.data?.content || post.content) {
    const doc = Array.isArray(post.data?.content) 
        ? { content: post.data.content } 
        : (post.data?.content || post.content)
        
    const rendered = tiptapToHtml(doc as any)
    if (rendered) {
        try {
            const processed = await unified()
                .use(rehypeParse, { fragment: true })
                .use(rehypeExpressiveCode, {
                    themes: ['github-dark'],
                    useThemedScrollbars: false,
                    styleOverrides: { borderRadius: '0.75rem', uiFontFamily: 'inherit' }
                })
                .use(rehypeStringify)
                .process(rendered)
                
            htmlContent = String(processed)
        } catch (e) {
            console.error('Error processing tiptap with expressive-code:', e)
            htmlContent = rendered
        }
    }
}
---

<Layout title={title} description={description} image={image} lang={locale === 'pt_BR' ? 'pt-BR' : 'en'}>
    <Header content={content.global.nav} locale={locale} />

    <main class='pt-24'>
        <article>
            <div
                class='container mx-auto px-6 max-w-4xl py-8'
            >
                <h1
                    class='font-serif text-primary text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6 lg:mb-8'
                >
                    {post.title}
                </h1>

                <div class='flex flex-wrap items-center gap-4 mb-6 lg:mb-8 text-text-muted text-sm font-medium'>
                   <div class='flex items-center gap-2'>
                        <svg xmlns='http://www.w3.org/2000/svg' class='w-4 h-4' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'>
                            <circle cx='12' cy='12' r='10'></circle>
                            <polyline points='12 6 12 12 16 14'></polyline>
                        </svg>
                        <span>{calculateReadingTime(post, locale)}</span>
                   </div>

                   {post.published_at && (
                       <div class='flex items-center gap-2'>
                            <svg xmlns='http://www.w3.org/2000/svg' class='w-4 h-4' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'>
                                <rect x='3' y='4' width='18' height='18' rx='2' ry='2'></rect>
                                <line x1='16' y1='2' x2='16' y2='6'></line>
                                <line x1='8' y1='2' x2='8' y2='6'></line>
                                <line x1='3' y1='10' x2='21' y2='10'></line>
                            </svg>
                           <time datetime={post.published_at}>
                               {formatDate(post.published_at, locale)}
                           </time>
                       </div>
                   )}
                </div>

                {post.categories && post.categories.length > 0 && (
                    <div class='mb-8 flex flex-wrap gap-2'>
                        {post.categories.map((cat) => {
                            const catHref = locale === 'pt_BR' ? `/br/${content.taxonomies.category.slug}/${cat.slug}` : `/category/${cat.slug}`
                            return (
                                <a href={catHref} class='inline-flex items-center rounded-full px-4 py-1.5 text-sm font-medium bg-primary/10 text-primary border border-primary/20 hover:bg-primary/20 transition-colors'>
                                    {cat.name}
                                </a>
                            )
                        })}
                    </div>
