530: <script>
531:     document.querySelectorAll(".share-btn").forEach((btn) => {
532:         btn.addEventListener("click", () => {
533:             const platform = btn.getAttribute("data-platform");
534:             const url = btn.getAttribute("data-url");
535:             const text = btn.getAttribute("data-text");
536: 
537:             const urls = {
538:                 twitter: `https://twitter.com/intent/tweet?url=${encodeURIComponent(url as string)}&text=${encodeURIComponent(text as string)}`,
539:                 linkedin: `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url as string)}`,
540:                 whatsapp: `https://api.whatsapp.com/send?text=${encodeURIComponent(`${text} ${url}`)}`,
541:             };
542: 
543:             window.open(
544:                 urls[platform as keyof typeof urls],
545:                 "_blank",
546:                 "width=600,height=400",
547:             );
548:         });
549:     });
550: 
551:     document.querySelectorAll(".copy-url-btn").forEach((btn) => {
552:         btn.addEventListener("click", async () => {
553:             const url = btn.getAttribute("data-url");
554:             if (!url) return;
555: 
556:             try {
557:                 await navigator.clipboard.writeText(url);
558: 
559:                 const copyIcon = btn.querySelector(".copy-url-icon");
560:                 const checkIcon = btn.querySelector(".check-icon");
561: 
562:                 copyIcon?.classList.add("hidden");
563:                 checkIcon?.classList.remove("hidden");
564: 
565:                 setTimeout(() => {
566:                     copyIcon?.classList.remove("hidden");
567:                     checkIcon?.classList.add("hidden");
568:                 }, 2000);
569:             } catch (err) {
570:                 console.error("Falha ao copiar URL:", err);
571:             }
572:         });
573:     });
574: </script>
