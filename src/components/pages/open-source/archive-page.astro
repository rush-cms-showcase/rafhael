---
import Layout from '@/layouts/layout.astro'
import Header from '@/components/layout/header.astro'
import Footer from '@/components/layout/footer.astro'
import Section from '@/components/ui/section.astro'
import Container from '@/components/ui/container.astro'
import ProjectCard from '@/components/open-source/project-card.astro'
import { homeContent } from '@/content/home'
import { extractProjectMeta } from '@/lib/open-source'
import type { ProjectMeta } from '@/lib/open-source'

interface Props {
	locale: 'en' | 'pt_BR'
}

const { locale } = Astro.props

const labels = {
	en: {
		title: 'Open Source',
		description: 'Open-source projects by Rafhael Marsigli. Tools built to solve real problems in AI-assisted development.',
		heading: 'Open Source',
		subtitle: 'Tools I build and share with the community.',
		pageTitle: 'Open Source - Rafhael Marsigli'
	},
	pt_BR: {
		title: 'Open Source',
		description: 'Projetos open-source de Rafhael Marsigli. Ferramentas construídas para resolver problemas reais no desenvolvimento assistido por IA.',
		heading: 'Open Source',
		subtitle: 'Ferramentas que construo e compartilho com a comunidade.',
		pageTitle: 'Open Source - Rafhael Marsigli'
	}
}

const t = labels[locale]
const siteContent = homeContent[locale]

const allModules = import.meta.glob('@/content/open-source/*.ts', { eager: true })

const projects: ProjectMeta[] = Object.entries(allModules)
	.map(([filepath, module]) =>
		extractProjectMeta(module as Record<string, unknown>, filepath, locale)
	)
	.filter((p): p is ProjectMeta => p !== null)
---

<Layout title={t.pageTitle} description={t.description} lang={locale === 'pt_BR' ? 'pt-BR' : 'en'}>
	<Header content={siteContent.global.nav} locale={locale} />

	<main>
		<Section>
			<Container>
				<div class="mb-12 lg:mb-20">
					<h1 class="font-serif text-4xl lg:text-6xl xl:text-7xl font-bold text-primary mb-4">
						{t.heading}
					</h1>
					<p class="text-text-muted text-lg lg:text-xl max-w-xl">
						{t.subtitle}
					</p>
				</div>

				{projects.length > 0 ? (
					<div class="grid md:grid-cols-2 gap-4 lg:gap-8">
						{projects.map(project => (
							<ProjectCard {...project} locale={locale} />
						))}
					</div>
				) : (
					<p class="text-text-muted text-lg">No projects yet.</p>
				)}
			</Container>
		</Section>
	</main>

	<Footer content={siteContent.global.footer} />
</Layout>
