---
import Layout from '@/layouts/layout.astro'
import HeaderLP from '@/components/layout/header.astro'
import HeroLP from '@/components/sections/lp/hero.astro'
import ProblemLP from '@/components/sections/lp/problem.astro'
import SolutionLP from '@/components/sections/lp/solution.astro'
import ProcessLP from '@/components/sections/lp/process.astro'
import PricingLP from '@/components/sections/lp/pricing.astro'
import FaqLP from '@/components/sections/common/faq.astro'
import Footer from '@/components/layout/footer.astro'
import WhatsappFloat from '@/components/ui/whatsapp-float.astro'

import { lpFastSiteContent } from '@/content/lp-fast-site'
import { homeContent } from '@/content/home'
import { buildWebPageSchema, buildServiceSchema, buildFAQSchema, buildSchemaGraph } from '@/lib/schema'

interface Props {
	locale: 'en' | 'pt_BR'
}

const { locale } = Astro.props

const content = lpFastSiteContent[locale]
const globalContent = homeContent[locale]

const title = content.metadata.title
const description = content.metadata.description
const ogImage = locale === 'pt_BR' ? '/images/lps/fast-website-banner-br.webp' : '/images/lps/fast-website-banner.webp'
const siteUrl = Astro.site?.origin || import.meta.env.SITE || 'https://rushcms.com'

const currency = locale === 'pt_BR' ? 'BRL' : 'USD'
const priceRaw = locale === 'pt_BR' ? '597' : '120'
const pageUrl = `${siteUrl}/${locale === 'pt_BR' ? 'br/site-rapido' : 'fast-website'}`

const schema = buildSchemaGraph(
	buildWebPageSchema({
		url: pageUrl,
		title,
		description,
		image: `${siteUrl}${ogImage}`,
	}),
	buildServiceSchema({
		serviceType: 'High Performance Website Development',
		providerName: 'Rafhael Marsigli',
		description,
		currency,
		price: priceRaw,
		url: `${pageUrl}#pricing`,
	}),
	buildFAQSchema(content.faq.items),
)
---

<Layout title={title} description={description} lang={locale.replace('_', '-')} image={ogImage} schema={schema}>
    <HeaderLP locale={locale} variant='minimal' position='absolute' />

    <main>
        <HeroLP content={content.hero} />
        <ProblemLP content={content.problem} />
        <SolutionLP content={content.solution} />
        <ProcessLP content={content.process} />
        <PricingLP content={content.pricing} />
        <FaqLP content={content.faq} />
    </main>

    <Footer content={globalContent.global.footer} />
    
    <WhatsappFloat message={content.pricing.whatsappMessage || ""} />
</Layout>
