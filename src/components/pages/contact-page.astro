---
import Layout from '@/layouts/layout.astro'
import Header from '@/components/layout/header.astro'
import Footer from '@/components/layout/footer.astro'
import Container from '@/components/ui/container.astro'
import { Icons } from '@/lib/icons'
import { homeContent } from '@/content/home'
import { contactContent } from '@/content/contact'

interface Props {
	locale: 'pt_BR' | 'en'
}

const { locale } = Astro.props
const globalContent = homeContent[locale]
const content = contactContent[locale]
const pageTitle = `${content.title} - Rafhael Marsigli`
---

<Layout title={pageTitle} description={content.description}>
    <div class='min-h-screen flex flex-col'>
        <Header content={globalContent.global.nav} locale={locale} />
        
        <main class='flex-1 flex items-center pt-32 pb-32 overflow-x-hidden'>
            <Container className='max-w-4xl relative z-10'>
                 <div class='absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] h-[300px] md:w-[600px] md:h-[600px] bg-primary/5 rounded-full blur-[60px] md:blur-[120px] pointer-events-none -z-10 max-w-[100vw]'></div>

                <div class='text-center mb-16 animate-fade-in'>
                    <div class='relative inline-block mx-auto mb-6'>
                        <div class='w-32 h-32 rounded-full border-4 border-bg-elevated shadow-xl overflow-hidden relative peer z-10'>
                            <div class='w-full h-full relative transition-all duration-[1500ms] ease-[cubic-bezier(0.34,1.56,0.64,1)] md:hover:rotate-[720deg] md:hover:scale-[5] origin-[55%_37%] group'>
                                <img 
                                    src='/profile-pic.webp' 
                                    alt='Rafhael Marsigli' 
                                    class='w-full h-full object-cover transition-all duration-700 group-hover:sepia group-hover:hue-rotate-[100deg] group-hover:saturate-[300%] group-hover:contrast-125'
                                />
                            </div>
                        </div>
                        <div class='hidden md:block absolute -top-6 -right-12 bg-bg-card border border-border px-4 py-2 rounded-xl rounded-bl-none shadow-lg z-20 animate-bounce [animation-duration:2s] opacity-0 peer-hover:opacity-100 transition-opacity duration-300 pointer-events-none'>
                            <span class='text-sm font-bold text-text-main whitespace-nowrap'>{content.hello}</span>
                        </div>
                    </div>
                    <h1 class='font-serif text-4xl md:text-5xl lg:text-6xl font-bold mb-6'>
                        {content.title}
                    </h1>
                    <p class='text-text-muted text-lg md:text-xl max-w-2xl mx-auto'>
                        {content.description}
                    </p>
                </div>

                <div class='grid md:grid-cols-2 gap-6 animate-fade-in-up delay-200'>
                    {content.channels.map((channel) => {
                        const Icon = Icons[channel.icon]
                        return (
                            <a 
                                href={channel.href}
                                target='_blank'
                                rel='noopener noreferrer'
                                class={`group p-8 rounded-2xl border border-border/50 bg-bg-elevated/50 backdrop-blur-sm transition-all duration-300 flex flex-col items-center justify-center text-center gap-4 ${channel.color}`}
                            >
                                <div class='w-16 h-16 rounded-full bg-bg-card flex items-center justify-center text-text-muted group-hover:text-inherit transition-colors shadow-lg group-hover:shadow-xl group-hover:scale-110 duration-300'>
                                    <Icon class='w-8 h-8' />
                                </div>
                                
                                <div>
                                    <h3 class='font-bold text-lg mb-1 text-text-main group-hover:text-inherit'>
                                        {channel.name}
                                    </h3>
                                    <p class='text-text-muted text-sm group-hover:text-inherit/80'>
                                        {channel.value}
                                    </p>
                                </div>
                            </a>
                        )
                    })}
                </div>
            </Container>
        </main>

        <Footer content={globalContent.global.footer} />
    </div>
</Layout>
