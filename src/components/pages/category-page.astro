---
import Layout from '@/layouts/layout.astro'
import Header from '@/components/layout/header.astro'
import Footer from '@/components/layout/footer.astro'
import Section from '@/components/ui/section.astro'
import Container from '@/components/ui/container.astro'
import BlogList from '@/components/blog/blog-list.astro'
import type { BlogPost } from '@/lib/rush'
import { homeContent } from '@/content/home'
import type { Page } from 'astro'

interface Props {
    page: Page<BlogPost>
    categoryName: string
    allCategories: { name: string; slug: string }[]
    locale: 'en' | 'pt_BR'
}

const { page, categoryName, allCategories, locale } = Astro.props
const currentPosts = page.data
const content = homeContent[locale]

const title = `${categoryName} - Blog - Rafhael Marsigli`
const description = locale === 'en' 
    ? `Articles about ${categoryName}` 
    : `Artigos sobre ${categoryName}`
---

<Layout title={title} description={description} noindex={page.total <= 5}>
    <Header content={content.global.nav} locale={locale} />
    <main class='pt-16 md:pt-12'>
        <Section>
            <Container>
                <div class='text-center mb-16 md:mb-24'>
                     <h1 class='font-serif text-5xl md:text-7xl mb-8 text-primary'>
                        {categoryName}
                    </h1>
                     <p class='text-xl text-text-muted'>
                        {content.taxonomies.category.label}
                    </p>
                </div>
                <BlogList 
                    initialPosts={currentPosts} 
                    categories={allCategories}
                    labels={content.blog} 
                    locale={locale}
                    taxonomies={content.taxonomies}
                    pagination={{
                        currentPage: page.currentPage,
                        lastPage: page.lastPage,
                        url: {
                            prev: page.url.prev,
                            next: page.url.next
                        }
                    }}
                />
            </Container>
        </Section>
    </main>
    <Footer content={content.global.footer} />
</Layout>
