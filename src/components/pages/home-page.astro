---
import Layout from "@/layouts/layout.astro";
import Header from "@/components/layout/header.astro";
import Hero from "@/components/sections/home/hero.astro";
import Philosophy from "@/components/sections/home/philosophy.astro";
import Stack from "@/components/sections/common/stack.astro";
import Projects from "@/components/sections/home/projects.astro";
import Beyond from "@/components/sections/home/beyond.astro";
import Testimonial from "@/components/sections/common/testimonial.astro";
import Footer from "@/components/layout/footer.astro";
import Section from "@/components/ui/section.astro";
import Button from "@/components/ui/button.astro";
import { homeContent } from "@/content/home";

interface Props {
    locale?: 'en' | 'pt_BR';
}

const { locale = 'en' } = Astro.props;
const content = homeContent[locale];

const title = content.metadata.title;
const description = content.metadata.description;
const scheduleUrl =
    import.meta.env.PUBLIC_SCHEDULE_URL ?? "https://cal.com/rafhael";
---

<Layout title={title} description={description}>
    {locale === 'en' && (
        <script is:inline slot="head">
            (function () {
                try {
                    var saved = localStorage.getItem("rush_lang_pref");
                    var lang = navigator.language || navigator.userLanguage;
                    if (
                        saved === "pt" ||
                        (!saved && lang && lang.startsWith("pt"))
                    ) {
                        window.location.replace("/br");
                    }
                } catch (e) {}
            })();
        </script>
    )}
    <Header content={content.global.nav} locale={locale} />

    <main>
        <Hero content={content.hero} />
        <Philosophy content={content.philosophy} />
        <Projects content={content.projects} />
        <Beyond content={content.beyond} />
        <Testimonial content={content.testimonial} />

        <Section class="text-center">
            <h2 class="font-serif text-4xl md:text-5xl font-bold mb-8">
                {content.ctaSection.title}
            </h2>
            <Button
                href={scheduleUrl}
                variant="primary"
                size="lg"
                className="shadow-lg shadow-primary/25"
            >
                {content.ctaSection.button}
            </Button>
        </Section>
    </main>

    <Footer content={content.global.footer} />
</Layout>
