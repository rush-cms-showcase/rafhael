---
import Layout from '@/layouts/layout.astro'
import Header from '@/components/layout/header.astro'
import Footer from '@/components/layout/footer.astro'
import AboutHero from '@/components/sections/about/about-hero.astro'
import AboutContent from '@/components/sections/about/about-content.astro'
import AboutConnect from '@/components/sections/about/about-connect.astro'
import type { HomeContent } from '@/content/home'

interface Props {
    content: HomeContent
    locale?: 'en' | 'pt_BR'
}

const { content, locale = 'en' } = Astro.props
const aboutContent = content.aboutMe
const linkedinUrl = import.meta.env.LINKEDIN_URL ?? 'https://www.linkedin.com/in/rafhael/'
---

<Layout title={`${aboutContent.title} | Rafhael Marsigli`} description={aboutContent.hero.subtitle}>
    <Header content={content.global.nav} locale={locale} />
    
    <main class='pt-24 pb-16 overflow-x-hidden'>
        <AboutHero content={aboutContent.hero} linkedinUrl={linkedinUrl} />
        <AboutContent content={{ quote: aboutContent.quote, journey: aboutContent.journey, philosophy: aboutContent.philosophy }} />
        <AboutConnect content={aboutContent.connect} />
    </main>

    <Footer content={content.global.footer} />
</Layout>
