---
import Layout from '@/layouts/layout.astro'
import Header from '@/components/layout/header.astro'
import Footer from '@/components/layout/footer.astro'
import Section from '@/components/ui/section.astro'
import Container from '@/components/ui/container.astro'
import { homeContent } from '@/content/home'

interface Props {
	locale: 'pt_BR' | 'en'
}

const { locale } = Astro.props
const globalContent = homeContent[locale]

const localizedStrings = {
    en: {
        title: 'Cases - Rafhael Marsigli',
        description: 'Explore my recent work and case studies.',
        comingSoon: 'Coming soon',
        message: "I'm preparing amazing cases and projects to showcase here. Check back soon!",
        backHome: 'Back to home',
        homeHref: '/'
    },
    pt_BR: {
        title: 'Cases - Rafhael Marsigli',
        description: 'Explore meus trabalhos e cases recentes.',
        comingSoon: 'Em breve',
        message: 'Estou preparando cases e projetos incríveis para mostrar aqui. Volte em breve!',
        backHome: 'Voltar para home',
        homeHref: '/br'
    }
}

const content = localizedStrings[locale]
---

<Layout title={content.title} description={content.description}>
	<Header content={globalContent.global.nav} locale={locale} />
	<main class='md:pt-8'>
		<Section>
			<Container className='text-center min-h-[60vh] flex flex-col items-center justify-center'>
				<div class='max-w-2xl mx-auto'>
					<h1 class='font-serif text-5xl lg:text-7xl font-bold mb-6 text-primary'>
						{content.comingSoon}
					</h1>
					<p class='text-xl text-text-muted mb-8'>
						{content.message}
					</p>
					<a
						href={content.homeHref}
						class='inline-flex items-center gap-2 text-primary hover:underline'
					>
						<svg
							xmlns='http://www.w3.org/2000/svg'
							class='w-5 h-5'
							viewBox='0 0 24 24'
							fill='none'
							stroke='currentColor'
							stroke-width='2'
						>
							<path d='M19 12H5'></path>
							<path d='M12 19l-7-7 7-7'></path>
						</svg>
						{content.backHome}
					</a>
				</div>
			</Container>
		</Section>
	</main>
	<Footer content={globalContent.global.footer} />
</Layout>
