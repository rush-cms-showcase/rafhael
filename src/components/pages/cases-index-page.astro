---
import Layout from '@/layouts/layout.astro'
import Header from '@/components/layout/header.astro'
import Footer from '@/components/layout/footer.astro'
import Section from '@/components/ui/section.astro'
import Container from '@/components/ui/container.astro'
import type { CasePost } from '@/lib/rush'
import { homeContent } from '@/content/home'
import type { Page } from 'astro'
import { Icons } from '@/lib/icons'

interface Props {
    page: Page<CasePost>
    locale: 'en' | 'pt_BR'
}

const { page, locale } = Astro.props
const currentPosts = page.data
const content = homeContent[locale]

const title = locale === 'en' ? 'Cases - Rafhael Marsigli' : 'Cases - Rafhael Marsigli'
const description =
    locale === 'en' ? 'Explore my recent work and case studies.' : 'Explore meus trabalhos e cases recentes.'
const readMore = locale === 'en' ? 'Read full case' : 'Ler case completo'
const basePath = locale === 'pt_BR' ? '/br' : ''
---

<Layout title={title} description={description}>
    <Header content={content.global.nav} locale={locale} />
    <main class="pt-16 md:pt-12">
        <Section>
            <Container>
                <div class="text-center">
                    <h2 class="text-primary text-4xl lg:text-6xl font-bold mb-12">Cases</h2>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
                    {
                        currentPosts.map((post) => {
                            return (
                                <a
                                    href={`${basePath}/cases/${post.slug}`}
                                    class="group flex flex-col rounded-2xl transition-all duration-300">
                                    <div class="flex flex-col flex-grow">
                                        <h3 class="text-3xl lg:text-4xl xl:text-5xl leading-14 font-serif font-bold text-text-strong mb-8 group-hover:text-primary group-hover:underline transition-colors">
                                            {post.title}
                                        </h3>
                                        <div class="flex items-center text-primary font-medium text-sm mt-auto border-t border-primary/10 pt-4">
                                            <span>{readMore}</span>
                                            <Icons.arrow_right class="w-4 h-4 ml-2 transition-transform group-hover:translate-x-1" />
                                        </div>
                                    </div>
                                </a>
                            )
                        })
                    }
                </div>

                {
                    page.lastPage > 1 && (
                        <div class="flex justify-center gap-4 mt-12 border-t border-border/30 pt-8">
                            {page.url.prev && (
                                <a
                                    href={page.url.prev}
                                    class="px-6 py-2 rounded-full border border-border text-text-subtle hover:text-primary hover:border-primary transition-colors">
                                    &larr; {locale === 'pt_BR' ? 'Anterior' : 'Previous'}
                                </a>
                            )}
                            <span class="px-6 py-2 text-text-muted">
                                {page.currentPage} / {page.lastPage}
                            </span>
                            {page.url.next && (
                                <a
                                    href={page.url.next}
                                    class="px-6 py-2 rounded-full border border-border text-text-subtle hover:text-primary hover:border-primary transition-colors">
                                    {locale === 'pt_BR' ? 'Próxima' : 'Next'} &rarr;
                                </a>
                            )}
                        </div>
                    )
                }
            </Container>
        </Section>
    </main>
    <Footer content={content.global.footer} />
</Layout>
