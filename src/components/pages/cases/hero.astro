---
import HeroBadge from './hero-badge.astro'
import { Icons, type IconName } from '@/lib/icons'
import type { CasePost } from '@/lib/rush'

interface Props {
    post: CasePost
}

const { post } = Astro.props

const resolveIcon = (name: string): IconName | null => {
    const key = name.toLowerCase().replace(/[^a-z0-9]/g, '')
    if (key === 'filamentphp') return 'filamentphp'
    if (key in Icons) return key as IconName
    return null
}
---

<div class="-mt-2 lg:mt-4">
    {
        post.featured_image && (
            <div class="w-full max-w-[1200px] -mb-8 lg:-mb-64">
                <img
                    src={post.featured_image.preview || post.featured_image.url}
                    alt={post.title}
                    class="w-full h-auto lg:rounded-xl"
                    fetchpriority="high"
                    decoding="async"
                />
            </div>
        )
    }
    <div class="p-3 lg:p-8 flex flex-col justify-center text-center gap-12 items-center z-10">
        <div
            class="flex flex-col gap-4 lg:gap-8 items-center max-w-[960px] border border-primary/10 bg-bg/75 backdrop-blur-lg p-4 py-6 lg:px-8 lg:py-12 rounded-lg">
            <h1 class="font-serif text-primary text-2xl md:text-5xl font-bold leading-tight">
                {post.title}
            </h1>
            {
                post.data?.stack && post.data.stack.length > 0 && (
                    <div class="flex items-start gap-4">
                        <div>
                            <div class="flex flex-wrap gap-3">
                                {post.data.stack.map((tech) => {
                                    const iconName = resolveIcon(tech)
                                    const IconComponent = iconName ? Icons[iconName] : null
                                    return (
                                        <div class="flex items-center gap-2 bg-bg-elevated border border-border p-2 rounded-full text-primary">
                                            {IconComponent ? (
                                                <IconComponent class="w-5 h-5 lg:h-6 lg:w-6" />
                                            ) : (
                                                <span class="text-primary">{tech}</span>
                                            )}
                                        </div>
                                    )
                                })}
                            </div>
                        </div>
                    </div>
                )
            }

            <div class="flex gap-2 flex-wrap justify-center">
                {[
                    { value: post.data?.client, Icon: Icons.users },
                    { value: post.data?.industry, Icon: Icons.box },
                    { value: post.data?.function, Icon: Icons.terminal },
                    { value: post.data?.period, Icon: Icons.calendar },
                ].map(({ value, Icon }) => value && (
                    <HeroBadge text={value}>
                        <Icon class="w-3.5 h-3.5" />
                    </HeroBadge>
                ))}
            </div>
        </div>
    </div>
</div>
